{
  "name": "impronta48/ledger-plugin",
  "description": "CakePHP plugin for ledger management with talent/EUR accounting",
  "type": "cakephp-plugin",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Ledger\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Ledger\\Test\\": "tests/"
    }
  },
  "require": {
    "php": ">=8.2",
    "cakephp/cakephp": "^5.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5 || ^11.1"
  },
  "extra": {
    "installer-name": "Ledger"
  }
}
